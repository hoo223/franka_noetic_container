<?xml version="1.0" ?>

<launch>
  <arg name="robot_ip" default="172.16.0.2" />
  <arg name="robot" default="panda" doc="choose your robot. Possible values: [panda, fr3]"/>
  <arg name="arm_id" default="$(arg robot)" />
  <arg name="load_gripper" default="true" />
  <arg name="spmouse" default="true" />
  <arg name="publish_rate" default="30" />
  <arg name="use_rviz" default="true" />

  <!-- Visualization -->
  <node pkg="rviz" type="rviz" output="log" name="rviz" args="-d $(find franka_interface)/launch/franka_visualization.rviz -f world --splash-screen $(find franka_interface)/splash.png"/>

  <node pkg="calibration_setup" type="world_to_base.py" name="world_to_base_broadcaster" output="log"/>
  <node pkg="calibration_setup" type="hand_to_handeye.py" name="hand_to_handeye_broadcaster" output="log"/>
  <!-- <node pkg="calibration_setup" type="world_to_part1.py" name="world_to_part1_broadcaster" output="log"/> -->
  <!-- <node pkg="calibration_setup" type="world_to_part11.py" name="world_to_part11_broadcaster" output="log"/> -->
  <!-- <node pkg="calibration_setup" type="tcp_to_part11.py" name="tcp_to_part11_broadcaster" output="log"/> -->
  <node pkg="calibration_setup" type="visualize_optical_breadboard.py" name="optical_breadboard_visualizer" output="log"/>

  <node name="vis_part1" pkg="calibration_setup" type="visualize_mesh_node.py" args="part1" output="log">
      <param name="mesh_path" value="file:///root/share/assets/mesh_part1/part1_with_uv.obj" />
      <param name="mesh_scale" value="1.0" />
  </node>
  <node name="vis_part11" pkg="calibration_setup" type="visualize_mesh_node.py" args="part11" output="log">
      <param name="mesh_path" value="file:///root/share/assets/mesh_part11/part11_with_uv.obj" />
      <param name="mesh_scale" value="1.0" />
  </node>


</launch>
