<?xml version="1.0" ?>

<launch>
  <arg name="load_gripper" default="true" />
  <arg name="robot_ip" default="172.16.0.2" />
  <arg name="publish_rate" default="30" />
  <arg name="robot" default="fr3" doc="choose your robot. Possible values: [panda, fr3]"/>

  <param name="robot_description" command="$(find xacro)/xacro $(find franka_description)/robots/$(arg robot)/$(arg robot).urdf.xacro arm_id:=panda hand:=$(arg load_gripper)" />

  <node name="robot_joint_state_publisher" pkg="franka_visualization" type="robot_joint_state_publisher" output="screen">
    <rosparam command="load" file="$(find franka_visualization)/config/robot_settings.yaml" />
    <param name="robot_ip" value="$(arg robot_ip)" />
    <param name="publish_rate" value="$(arg publish_rate)" />
  </node>

  <node name="gripper_joint_state_publisher" pkg="franka_visualization" type="gripper_joint_state_publisher" output="screen" if="$(arg load_gripper)">
    <rosparam command="load" file="$(find franka_visualization)/config/gripper_settings.yaml" />
    <param name="robot_ip" value="$(arg robot_ip)" />
    <param name="publish_rate" value="$(arg publish_rate)" />
  </node>

  <node name="joint_state_publisher" type="joint_state_publisher" pkg="joint_state_publisher" output="screen">
    <param name="rate" value="$(arg publish_rate)" />
    <rosparam param="source_list">[robot_joint_state_publisher/joint_states, gripper_joint_state_publisher/joint_states]</rosparam>
  </node>

  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />
  <node pkg="rviz" type="rviz" output="screen" name="rviz" args="-d $(find franka_visualization)/launch/franka_visualization.rviz -f world --splash-screen $(find franka_visualization)/splash.png"/>

  <node pkg="calibration_setup" type="world_to_base.py" name="world_to_base_broadcaster" output="screen"/>
  <!-- <node pkg="calibration_setup" type="tcp_to_world.py" name="tcp_to_world_broadcaster" output="screen"/> -->
  <node pkg="calibration_setup" type="hand_to_handeye.py" name="hand_to_handeye_broadcaster" output="screen"/>
  <node pkg="calibration_setup" type="object_pose_to_tf.py" name="handeye_to_object_broadcaster" output="screen"/>
  <!-- <node pkg="calibration_setup" type="world_to_part1.py" name="world_to_part1_broadcaster" output="screen"/> -->
  <node pkg="calibration_setup" type="visualize_optical_breadboard.py" name="optical_breadboard_visualizer" output="screen"/>
  <!-- <node pkg="calibration_setup" type="world_to_handeye.py" name="world_to_handeye_broadcaster" output="screen"/> -->
  <!-- <node pkg="calibration_setup" type="handeye_to_world.py" name="handeye_to_world_broadcaster" output="screen"/> -->
  <!-- <node pkg="calibration_setup" type="depth_to_color.py" name="depth_to_color_broadcaster" output="screen"/> -->

</launch>
